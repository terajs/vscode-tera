{
  "scopeName": "text.html.tera",
  "patterns": [
    { "include": "#script-block" },
    { "include": "#style-block" },
    { "include": "#meta-block" },
    { "include": "#route-block" },
    { "include": "#ai-block" },
    { "include": "#template-block" }
  ],
  "repository": {
    "script-block": {
      "begin": "(<)(script)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.script.html.tera" },
        "3": { "patterns": [{ "include": "#html-tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(script)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.script.html.tera" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "contentName": "meta.embedded.block.typescript.tera",
      "patterns": [
        { "include": "source.ts" }
      ]
    },
    "template-block": {
      "begin": "(<)(template)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.template.html.tera" },
        "3": { "patterns": [{ "include": "#html-tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(template)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.template.html.tera" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "patterns": [
        { "include": "#template-interpolation" },
        { "include": "#template-component-tag" },
        { "include": "#template-tag" },
        { "include": "text.html.basic" }
      ]
    },
    "template-tag": {
      "begin": "(<)([a-z][\\w:-]*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" }
      },
      "end": "(/?>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.html" }
      },
      "patterns": [{ "include": "#html-tag-attributes" }]
    },
    "template-component-tag": {
      "begin": "(<)([A-Z][\\w:-]*|[a-z][\\w:-]*-[\\w:-]*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html support.class.component.html.tera" }
      },
      "end": "(/?>)",
      "endCaptures": { "1": { "name": "punctuation.definition.tag.end.html" } },
      "patterns": [{ "include": "#html-tag-attributes" }]
    },
    "html-tag-attributes": {
      "patterns": [
        { "include": "#conditional-directive-attribute" },
        { "include": "#loop-directive-attribute" },
        { "include": "#directive-attribute" },
        { "match": "\\b[A-Za-z_][\\w:.-]*", "name": "entity.other.attribute-name.html" },
        { "match": "=", "name": "punctuation.separator.key-value.html" },
        { "begin": "\"", "end": "\"", "name": "string.quoted.double.html" },
        { "begin": "'", "end": "'", "name": "string.quoted.single.html" }
      ]
    },
    "conditional-directive-attribute": {
      "begin": "(v-(?:if|else-if|else|show))(\\s*)(=)(\\s*)([\"'])",
      "beginCaptures": {
        "1": { "name": "entity.other.attribute-name.html keyword.control.conditional.tera" },
        "3": { "name": "punctuation.separator.key-value.html" },
        "5": { "name": "punctuation.definition.string.begin.html" }
      },
      "end": "\\5",
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.html" } },
      "patterns": [{ "include": "source.ts" }]
    },
    "loop-directive-attribute": {
      "begin": "(v-for)(\\s*)(=)(\\s*)([\"'])",
      "beginCaptures": {
        "1": { "name": "entity.other.attribute-name.html keyword.control.loop.tera" },
        "3": { "name": "punctuation.separator.key-value.html" },
        "5": { "name": "punctuation.definition.string.begin.html" }
      },
      "end": "\\5",
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.html" } },
      "patterns": [{ "include": "source.ts" }]
    },
    "directive-attribute": {
      "begin": "([@:][\\w:.-]+|v-[\\w:.-]+)(\\s*)(=)(\\s*)([\"'])",
      "beginCaptures": {
        "1": { "name": "entity.other.attribute-name.html" },
        "3": { "name": "punctuation.separator.key-value.html" },
        "5": { "name": "punctuation.definition.string.begin.html" }
      },
      "end": "\\5",
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.html" } },
      "patterns": [{ "include": "source.ts" }]
    },
    "template-interpolation": {
      "begin": "\\{\\{",
      "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.tera" } },
      "end": "\\}\\}",
      "endCaptures": { "0": { "name": "punctuation.section.embedded.end.tera" } },
      "patterns": [{ "include": "source.ts" }]
    },
    "style-block": {
      "begin": "(<)(style)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.style.html.tera" },
        "3": { "patterns": [{ "include": "#html-tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(style)(>)",
      "contentName": "meta.embedded.block.css.tera",
      "patterns": [{ "include": "source.css" }]
    },
    "meta-block": {
      "begin": "(<)(meta)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "storage.type.block.tera" },
        "4": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(meta)(>)",
      "patterns": [{ "include": "#tera-yaml-body" }]
    },
    "route-block": {
      "begin": "(<)(route)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "storage.type.block.tera" },
        "4": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(route)(>)",
      "patterns": [{ "include": "#tera-yaml-body" }]
    },
    "ai-block": {
      "begin": "(<)(ai)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "storage.type.block.tera" },
        "4": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(ai)(>)",
      "patterns": [{ "include": "#tera-yaml-body" }]
    },
    "tera-yaml-body": {
      "patterns": [
        { "match": "^\\s*#.*$", "name": "comment.line.number-sign.tera" },
        { "match": "^\\s*([A-Za-z_][\\w:-]*)(\\s*)(:)", "captures": { "1": { "name": "support.type.property-name.tera" }, "3": { "name": "punctuation.separator.key-value.tera" } } },
        { "match": "\\b(true|false|auto|eager|visible|idle|interaction|none|ai|low|normal|high)\\b", "name": "constant.language.tera" },
        { "match": "\\b\\d+(?:\\.\\d+)?\\b", "name": "constant.numeric.tera" },
        { "begin": "[\"']", "end": "[\"']", "name": "string.quoted.tera" }
      ]
    }
  }
}