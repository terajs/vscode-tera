      ]
    },
    "style-sass-block": {
      "begin": "(<)(style)\\b(?=[^>]*\\blang=[\"']sass[\"'])",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "storage.type.block.tera"
        }
      },
      "end": "(</)(style)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "storage.type.block.tera"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "contentName": "meta.embedded.block.sass.tera",
      "patterns": [
        {
          "include": "#block-tag-attributes"
        },
        {
          "include": "source.sass"
        }
      ]
    },
    "style-less-block": {
      "begin": "(<)(style)\\b(?=[^>]*\\blang=[\"']less[\"'])",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "storage.type.block.tera"
        }
      },
      "end": "(</)(style)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "storage.type.block.tera"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "contentName": "meta.embedded.block.less.tera",
      "patterns": [
        {
          "include": "#block-tag-attributes"
        },
        {
          "include": "source.less"
        }
      ]
    },
    "style-default-block": {
      "begin": "(<)(style)\\b",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "storage.type.block.tera"
        }
      },
      "end": "(</)(style)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "storage.type.block.tera"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "contentName": "meta.embedded.block.css.tera",
      "patterns": [
        {
          "include": "#block-tag-attributes"
        },
        {
          "include": "source.css"
        }
      ]
    },
    "meta-block": {
      "begin": "(<)(meta)\\b",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "storage.type.block.tera"
        }
      },
      "end": "(</)(meta)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "storage.type.block.tera"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "contentName": "meta.embedded.block.meta.tera",
      "patterns": [
        {
          "include": "#block-tag-attributes"
        },
        {
          "include": "#tera-yaml-body"
        }
      ]
    },
    "route-block": {
      "begin": "(<)(route)\\b",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "storage.type.block.tera"
        }
      },
      "end": "(</)(route)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
