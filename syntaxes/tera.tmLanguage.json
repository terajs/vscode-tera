{
  "scopeName": "text.html.tera",
  "patterns": [
    {
      "include": "#template-block"
    },
    {
      "include": "#script-ts-block"
    },
    {
      "include": "#script-js-block"
    },
    {
      "include": "#script-default-block"
    },
    {
      "include": "#style-scss-block"
    },
    {
      "include": "#style-sass-block"
    },
    {
      "include": "#style-less-block"
    },
    {
      "include": "#style-default-block"
    },
    {
      "include": "#meta-block"
    },
    {
      "include": "#route-block"
    },
    {
      "include": "#ai-block"
    }
  ],
  "repository": {
    "template-block": {
      "begin": "(<)(template)\\b",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
            "name": "entity.name.tag.$2.html.tera"
        }
      },
      "end": "(</)(template)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
            "name": "entity.name.tag.$2.html.tera"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "contentName": "text.html.derivative",
      "patterns": [
        {
          "include": "#block-tag-attributes"
        },
        {
          "include": "#template-interpolation"
        },
        {
          "include": "#template-directive-tag"
        },
        {
          "include": "#template-component-tag"
        },
        {
          "include": "text.html.derivative"
        }
      ]
    },
    "template-interpolation": {
      "begin": "\\{\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.embedded.begin.tera"
        }
      },
      "end": "\\}\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.embedded.end.tera"
        }
      },
      "name": "meta.interpolation.tera",
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    },
    "block-tag-attributes": {
      "begin": "\\G",
      "end": "(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "patterns": [
        {
          "include": "#html-tag-attributes"
        }
      ]
    },
    "html-tag-attributes": {
      "patterns": [
        {
          "include": "#directive-control-double-quoted-attribute"
        },
        {
          "include": "#directive-control-single-quoted-attribute"
        },
        {
          "include": "#directive-double-quoted-attribute"
        },
        {
          "include": "#directive-single-quoted-attribute"
        },
        {
          "match": "((v-for)|(v-if|v-else-if|v-else))(?=[\\s>/])",
          "captures": {
            "2": {
              "name": "keyword.control.loop.tera"
            },
            "3": {
              "name": "keyword.control.conditional.tera"
            }
          }
        },
        {
          "match": "[@:][A-Za-z_][\\w:.-]*|v-[A-Za-z_][\\w:.-]*",
          "name": "entity.other.attribute-name.html"
        },
        {
          "match": "\\b[A-Za-z_][\\w:.-]*",
          "name": "entity.other.attribute-name.html"
        },
        {
          "match": "=",
          "name": "punctuation.separator.key-value.html"
        },
        {
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.html"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.html"
            }
          },
          "name": "string.quoted.double.html"
        },
        {
          "begin": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.html"
            }
          },
          "end": "'",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.html"
            }
          },
          "name": "string.quoted.single.html"
        }
      ]
    },
    "directive-control-double-quoted-attribute": {
      "begin": "((v-for)|(v-if|v-else-if|v-else))(\\s*)(=)(\\s*)(\")",
      "beginCaptures": {
        "2": {
          "name": "keyword.control.loop.tera"
        },
        "3": {
          "name": "keyword.control.conditional.tera"
        },
        "5": {
          "name": "punctuation.separator.key-value.html"
        },
        "7": {
          "name": "punctuation.definition.string.begin.html"
        }
      },
      "end": "\"",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.html"
        }
      },
      "contentName": "source.ts.tera-attribute",
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    },
    "directive-control-single-quoted-attribute": {
      "begin": "((v-for)|(v-if|v-else-if|v-else))(\\s*)(=)(\\s*)(')",
      "beginCaptures": {
        "2": {
          "name": "keyword.control.loop.tera"
        },
        "3": {
          "name": "keyword.control.conditional.tera"
        },
        "5": {
          "name": "punctuation.separator.key-value.html"
        },
        "7": {
          "name": "punctuation.definition.string.begin.html"
        }
      },
      "end": "'",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.html"
        }
      },
      "contentName": "source.ts.tera-attribute",
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    },
    "directive-double-quoted-attribute": {
      "begin": "([@:][A-Za-z_][\\w:.-]*|v-[A-Za-z_][\\w:.-]*)(\\s*)(=)(\\s*)(\")",
      "beginCaptures": {
        "1": {
          "name": "entity.other.attribute-name.html"
        },
        "3": {
          "name": "punctuation.separator.key-value.html"
        },
        "5": {
          "name": "punctuation.definition.string.begin.html"
        }
      },
      "end": "\"",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.html"
        }
      },
      "contentName": "source.ts.tera-attribute",
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    },
    "directive-single-quoted-attribute": {
      "begin": "([@:][A-Za-z_][\\w:.-]*|v-[A-Za-z_][\\w:.-]*)(\\s*)(=)(\\s*)(')",
      "beginCaptures": {
        "1": {
          "name": "entity.other.attribute-name.html"
        },
        "3": {
          "name": "punctuation.separator.key-value.html"
        },
        "5": {
          "name": "punctuation.definition.string.begin.html"
        }
      },
      "end": "'",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.html"
        }
      },
      "contentName": "source.ts.tera-attribute",
      "patterns": [
        {
          "include": "source.ts"
        }
      ]
    },
    "template-directive-tag": {
      "begin": "(</?)([A-Za-z][\\w:-]*)(?=[^>]*(?:\\s|^)(?:[@:][A-Za-z_][\\w:.-]*|v-[A-Za-z_][\\w:.-]*)(?:\\s*=|(?=[\\s>/])))",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        }
      },
      "end": "(/?>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "patterns": [
        {
          "include": "#html-tag-attributes"
        }
      ]
    },
    "template-component-tag": {
      "begin": "(</?)([A-Z][\\w:-]*|[a-z][\\w:-]*-[\\w:-]*)(?=[\\s>/])",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        }
      },
      "end": "(/?>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "patterns": [
        {
          "include": "#html-tag-attributes"
        }
      ]
    },
    "script-ts-block": {
      "begin": "(<)(script)\\b(?=[^>]*\\blang=[\"'](?:ts|tsx)[\"'])",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.$2.html.tera"
        }
      },
      "end": "(</)(script)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.$2.html.tera"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "contentName": "meta.embedded.block.typescript.tera",
      "patterns": [
        {
          "include": "#block-tag-attributes"
        },
        {
          "include": "source.ts"
        }
      ]
    },
    "script-js-block": {
      "begin": "(<)(script)\\b(?=[^>]*\\blang=[\"'](?:js|jsx|javascript)[\"'])",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.$2.html.tera"
        }
      },
      "end": "(</)(script)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.$2.html.tera"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "contentName": "meta.embedded.block.javascript.tera",
      "patterns": [
        {
          "include": "#block-tag-attributes"
        },
        {
          "include": "source.js"
        }
      ]
    },
    "script-default-block": {
      "begin": "(<)(script)\\b",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.$2.html.tera"
        }
      },
      "end": "(</)(script)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.$2.html.tera"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "contentName": "meta.embedded.block.typescript.tera",
      "patterns": [
        {
          "include": "#block-tag-attributes"
        },
        {
          "include": "source.ts"
        }
      ]
    },
    "style-scss-block": {
      "begin": "(<)(style)\\b(?=[^>]*\\blang=[\"']scss[\"'])",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "storage.type.block.tera"
        }
      },
      "end": "(</)(style)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "storage.type.block.tera"
        },
        "3": {
