          "include": "#block-tag-attributes"
        },
        {
          "include": "#tera-yaml-body"
        }
      ]
    },
    "tera-yaml-body": {
      "patterns": [
        {
          "match": "^\\s*#.*$",
          "name": "comment.line.number-sign.tera"
        },
        {
          "match": "^\\s*(-)",
          "captures": {
            "1": {
              "name": "punctuation.definition.sequence.item.tera"
            }
          }
        },
        {
          "match": "^\\s*([A-Za-z_][\\w:-]*)(\\s*)(:)",
          "captures": {
            "1": {
              "name": "support.type.property-name.tera"
            },
            "3": {
              "name": "punctuation.separator.key-value.tera"
            }
          }
        },
        {
          "match": "\\b(true|false)\\b",
          "name": "constant.language.boolean.tera"
        },
        {
          "match": "\\b(auto|eager|visible|idle|interaction|none|ai|low|normal|high)\\b",
          "name": "constant.language.enum.tera"
        },
        {
          "match": "\\b\\d+(?:\\.\\d+)?\\b",
          "name": "constant.numeric.tera"
        },
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.tera"
        },
        {
          "begin": "'",
          "end": "'",
          "name": "string.quoted.single.tera"
        }
      ]
    }
